    fill.Size = UDim2.new(rel, 0, 1, 0)
end)

-- ────────────────────────────────────── Core Logic ───

local function isValidTarget(char)
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if Settings.TeamCheck and char:FindFirstChild("TeamColor") and lp.Character
        and lp.Character:FindFirstChild("TeamColor") then
        if char.TeamColor == lp.Character.TeamColor then return false end
    end
    return true
end

local function getClosestToCursor()
    local mouse = UserInput:GetMouseLocation()
    local closest, bestDist = nil, Settings.FOV + 1

    for _, p in Players:GetPlayers() do
        if p == lp then continue end
        local c = p.Character
        if not isValidTarget(c) then continue end

        local part = c:FindFirstChild(Settings.TargetPart) or c:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        local screen, vis = Camera:WorldToViewportPoint(part.Position)
        if not vis then continue end

        if Settings.VisibleCheck then
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {lp.Character or {}}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local res = workspace:Raycast(Camera.CFrame.Position,
                (part.Position - Camera.CFrame.Position).Unit * 3000, rp)
            if res and res.Instance:IsDescendantOf(c) == false then continue end
        end

        local dist = (Vector2.new(screen.X, screen.Y) - mouse).Magnitude
        if dist < bestDist then bestDist = dist; closest = part end
    end
    return closest
end

-- ────────────────────────────────────── Triggerbot ───

local triggerTimer   = 0
local lastShotTime   = 0

local function runTriggerbot(dt)
    if not Settings.TriggerEnabled then
        triggerTimer = 0
        return
    end

    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2

    -- Raycast through screen center
    local unitRay = Camera:ScreenPointToRay(cx, cy)
    local rp = RaycastParams.new()
    if lp.Character then
        rp.FilterDescendantsInstances = {lp.Character}
        rp.FilterType = Enum.RaycastFilterType.Exclude
    end
    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 2500, rp)

    local onTarget = false

    -- check raycast hit
    if result and result.Instance then
        for _, p in Players:GetPlayers() do
            if p ~= lp and p.Character and result.Instance:IsDescendantOf(p.Character) then
                if isValidTarget(p.Character) then
                    onTarget = true
                end
                break
            end
        end
    end

    -- fallback: screen-space proximity check
    if not onTarget then
        for _, p in Players:GetPlayers() do
            if p ~= lp and p.Character and isValidTarget(p.Character) then
                local part = p.Character:FindFirstChild("Head")
                    or p.Character:FindFirstChild("HumanoidRootPart")
                if part then
                    local sp, vis = Camera:WorldToViewportPoint(part.Position)
                    if vis then
                        local d = math.sqrt((sp.X - cx)^2 + (sp.Y - cy)^2)
                        if d <= Settings.TriggerFOV then
                            onTarget = true
                            break
                        end
                    end
                end
            end
        end
    end

    if onTarget then
        triggerTimer = triggerTimer + dt
        if triggerTimer >= Settings.TriggerDelay then
            local now = tick()
            if now - lastShotTime >= Settings.TriggerCooldown then
                mouse1press()
                task.delay(0.065, mouse1release)
                lastShotTime = now
            end
            triggerTimer = 0
        end
    else
        triggerTimer = 0
    end
end

-- ────────────────────────────────────── Input ───

UserInput.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.KeyCode == Settings.FlickKey then
        if Settings.HoldToFlick then
            Settings.Enabled = true
            toggleBtn.Text = "Aimbot  ON  (Q)"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(55, 175, 85)
        else
            updateAimbotUI()
        end
    end
end)

UserInput.InputEnded:Connect(function(inp)
    if inp.KeyCode == Settings.FlickKey and Settings.HoldToFlick then
        Settings.Enabled = false
        toggleBtn.Text = "Aimbot  OFF  (Q)"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    end
end)

-- ────────────────────────────────────── Main Loop ───

local currentTarget = nil

RunService.RenderStepped:Connect(function(dt)
    local mousePos = UserInput:GetMouseLocation()
    fovCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    fovCircle.Radius   = Settings.FOV

    -- triggerbot always runs when enabled
    runTriggerbot(dt)

    if not Settings.Enabled then
        currentTarget = nil
        if Settings.TriggerEnabled then
            statLbl.Text = "Trigger active"
            statLbl.TextColor3 = Color3.fromRGB(55, 130, 210)
        else
            statLbl.Text = "Ready"
            statLbl.TextColor3 = Color3.fromRGB(130, 130, 155)
        end
        return
    end

    currentTarget = getClosestToCursor()

    if currentTarget then
        local goalCFrame = CFrame.lookAt(Camera.CFrame.Position, currentTarget.Position)
        local speed = UserInput:IsKeyDown(Settings.FlickKey)
            and Settings.FlickSpeed or Settings.SmoothAfterFlick
        TweenService:Create(Camera, TweenInfo.new(speed, Enum.EasingStyle.Quad,
            Enum.EasingDirection.Out), {CFrame = goalCFrame}):Play()
        statLbl.Text = "Aim → " .. currentTarget.Parent.Name
        statLbl.TextColor3 = Color3.fromRGB(55, 175, 85)
    else
        statLbl.Text = "No target in FOV"
        statLbl.TextColor3 = Color3.fromRGB(210, 140, 40)
    end
end)

